VITE_MAPBOX_TOKEN=pk.eyJ1...

# Google Maps Embed API key — enables embedded Street View inside the
# satellite preview modal. Free / unlimited for the Embed API.
# Get one at https://console.cloud.google.com/ (enable "Maps Embed API",
# create an API key, restrict it to your domain).
VITE_GOOGLE_MAPS_EMBED_KEY=AIza...

# Google Street View Static API key — replaces the top-down satellite
# thumbnails on listing cards with real ground-level photos of the actual
# address. If unset, the app falls back to VITE_GOOGLE_MAPS_EMBED_KEY (the
# Static API can share the same Google Cloud key as long as the
# "Street View Static API" is enabled on the project). Final fallback is a
# top-down Mapbox aerial centered on the address.
VITE_GOOGLE_STREETVIEW_KEY=AIza...

