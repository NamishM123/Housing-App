# Copy this file to .env and fill in your API keys

# OpenAI API — https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# RentCast API (free tier) — https://app.rentcast.io/
RENTCAST_API_KEY=your_rentcast_key_here

# Walk Score API (free) — https://www.walkscore.com/professional/api.php
WALKSCORE_API_KEY=your_walkscore_key_here

# Mapbox — https://account.mapbox.com/access-tokens/
# (also goes in client/.env as VITE_MAPBOX_TOKEN)
MAPBOX_TOKEN=pk.eyJ1...
